{
  "manifest_version": 3,
  "name": "SusMode: Sustainable Browser Extension",
  "version": "1.0.0",
  "description": "A sustainable browser extension to promote eco-friendly browsing habits",
  "permissions": ["scripting", "storage", "activeTab", "declarativeNetRequest", "alarms"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "SusMode"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}